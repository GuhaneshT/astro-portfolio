---
import { SITE_TITLE } from '../consts';
// If you don't have consts.js, you can remove this import and hardcode the title below
---

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Contact Me | Your Site Title</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <!-- You can add your site's meta tags here -->
</head>
<body>
    <header>
        <nav>
            <!-- Mobile Menu Toggle Buttons -->
            <div class="menu-controls">
                <button id="menu-toggle" class="menu-toggle" aria-label="Open Menu">
                    ☰
                </button>
                <button id="menu-close" class="menu-close" aria-label="Close Menu">
                    ✕
                </button>
            </div>

            <!-- Internal Links (Mobile Menu) -->
            <div id="menu" class="internal-links">
                <a href="/">Home</a>
                <a href="/blog">Projects</a>
                <a href="/about">About</a>
                <a href="/contact">Contact</a>
            </div>

            <!-- Social Links -->
            <div class="social-links">
                <a href="https://twitter.com/astrodotbuild" target="_blank">
                    <svg viewBox="0 0 16 16" aria-hidden="true" width="16" height="16">
                        <path fill="currentColor" d="M5.026 15c6.038 0 9.341-5.003..."></path>
                    </svg>
                </a>
                <a href="https://github.com/withastro/astro" target="_blank">
                    <svg viewBox="0 0 16 16" aria-hidden="true" width="16" height="16">
                        <path fill="currentColor" d="M8 0C3.58 0 0 3.58 0 8..."></path>
                    </svg>
                </a>
            </div>
        </nav>
    </header>

    <main>
        <section class="hero">
            <h1>Contact Me</h1>
            <p>Have a question or want to work together? Get in touch!</p>
        </section>

        <section class="contact-container">
            <div class="contact-info">
                <h2>Let's Connect</h2>
                <p>Feel free to reach out through any of the following methods:</p>
                
                <div class="contact-methods">
                    <div class="contact-method">
                        <div class="icon">📧</div>
                        <div class="details">
                            <h3>Email</h3>
                            <p><a href="mailto:hello@yourdomain.com">hello@yourdomain.com</a></p>
                        </div>
                    </div>
                    
                    <div class="contact-method">
                        <div class="icon">📱</div>
                        <div class="details">
                            <h3>Social Media</h3>
                            <div class="social-links-contact">
                                <a href="https://twitter.com/yourusername" target="_blank">Twitter</a>
                                <a href="https://github.com/yourusername" target="_blank">GitHub</a>
                                <a href="https://linkedin.com/in/yourusername" target="_blank">LinkedIn</a>
                            </div>
                        </div>
                    </div>
                    
                    <div class="contact-method">
                        <div class="icon">📍</div>
                        <div class="details">
                            <h3>Location</h3>
                            <p>City, Country</p>
                        </div>
                    </div>
                </div>
            </div>
            
            <div class="contact-form">
                <h2>Send a Message</h2>
                <form id="contact-form">
                    <div class="form-group">
                        <label for="name">Name</label>
                        <input type="text" id="name" name="name" required>
                    </div>
                    
                    <div class="form-group">
                        <label for="email">Email</label>
                        <input type="email" id="email" name="email" required>
                    </div>
                    
                    <div class="form-group">
                        <label for="subject">Subject</label>
                        <input type="text" id="subject" name="subject" required>
                    </div>
                    
                    <div class="form-group">
                        <label for="message">Message</label>
                        <textarea id="message" name="message" rows="5" required></textarea>
                    </div>
                    
                    <button type="submit" class="submit-btn">Send Message</button>
                </form>
            </div>
        </section>
    </main>

    <footer>
        <p>&copy; {new Date().getFullYear()} Your Name. All rights reserved.</p>
    </footer>
</body>
</html>

<style>
    /* CSS Variables */
    :root {
        --black: #13151a;
        --accent: #4c6ef5;
        --accent-dark: #364fc7;
        --text: #444;
        --text-light: #666;
        --background: #f8f9fa;
        --input-bg: #f5f5f5;
    }

    /* Global Styles */
    * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
    }

    body {
        font-family: system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, 'Open Sans', 'Helvetica Neue', sans-serif;
        color: var(--text);
        background-color: var(--background);
        line-height: 1.6;
    }

    a {
        color: var(--accent);
        text-decoration: none;
        transition: color 0.3s ease;
    }

    a:hover {
        color: var(--accent-dark);
    }

    /* Header Styling */
    header {
        margin: 0;
        padding: 0 1em;
        background: var(--black);
        position: sticky;
        top: 0;
        width: 100%;
        z-index: 1000;
    }

    /* Navigation Layout */
    nav {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 1em 0;
        position: relative;
    }

    /* Menu Controls Container */
    .menu-controls {
        position: relative;
        padding-left: 1rem;
    }

    /* Internal Links */
    .internal-links {
        display: flex;
        gap: 1rem;
    }

    nav a {
        padding: 1em 0.5em;
        color: var(--accent);
        text-decoration: none;
        transition: 0.3s ease-in-out;
    }

    nav a:hover {
        color: var(--accent-dark);
    }

    /* Social Links */
    .social-links {
        display: flex;
        gap: 1rem;
    }

    /* Mobile Menu Buttons */
    .menu-toggle,
    .menu-close {
        display: none;
        background: none;
        border: none;
        color: var(--accent);
        font-size: 1.5rem;
        line-height: 1;
        cursor: pointer;
        z-index: 1100;
        transition: opacity 0.3s ease-in-out;
        padding: 0.5rem;
    }

    /* Main Content Styling */
    main {
        width: 100%;
        max-width: 1200px;
        margin: 0 auto;
        padding: 2rem;
    }
    
    /* Hero Section */
    .hero {
        text-align: center;
        margin-bottom: 3rem;
    }
    
    .hero h1 {
        font-size: 2.5rem;
        margin-bottom: 0.5rem;
        color: var(--accent);
    }
    
    .hero p {
        font-size: 1.2rem;
        color: var(--text-light);
    }
    
    /* Contact Container */
    .contact-container {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 3rem;
        margin-bottom: 3rem;
    }
    
    /* Contact Info */
    .contact-info h2,
    .contact-form h2 {
        font-size: 1.8rem;
        margin-bottom: 1.5rem;
        color: var(--accent);
    }
    
    .contact-methods {
        margin-top: 2rem;
    }
    
    .contact-method {
        display: flex;
        align-items: flex-start;
        margin-bottom: 1.5rem;
    }
    
    .icon {
        font-size: 1.5rem;
        margin-right: 1rem;
        min-width: 30px;
    }
    
    .details h3 {
        font-size: 1.2rem;
        margin-bottom: 0.5rem;
        color: var(--accent);
    }
    
    .details p {
        margin: 0;
        color: var(--text-light);
    }
    
    .social-links-contact {
        display: flex;
        gap: 1rem;
    }
    
    .social-links-contact a {
        color: var(--accent);
        text-decoration: none;
        transition: color 0.3s ease;
    }
    
    .social-links-contact a:hover {
        color: var(--accent-dark);
    }
    
    /* Contact Form */
    .form-group {
        margin-bottom: 1.5rem;
    }
    
    label {
        display: block;
        margin-bottom: 0.5rem;
        color: var(--text-light);
    }
    
    input,
    textarea {
        width: 100%;
        padding: 0.8rem;
        border: 1px solid #ccc;
        border-radius: 4px;
        background-color: var(--input-bg);
        color: var(--text);
        font-family: inherit;
    }
    
    textarea {
        resize: vertical;
    }
    
    .submit-btn {
        background-color: var(--accent);
        color: white;
        border: none;
        padding: 0.8rem 1.5rem;
        font-size: 1rem;
        border-radius: 4px;
        cursor: pointer;
        transition: background-color 0.3s ease;
    }
    
    .submit-btn:hover {
        background-color: var(--accent-dark);
    }
    
    /* Footer Styling */
    footer {
        text-align: center;
        padding: 2rem;
        background-color: var(--black);
        color: #fff;
    }

    /* Full-Screen Mobile Menu */
    @media (max-width: 720px) {
        /* Hide social links on smaller screens */
        .social-links {
            display: none;
        }

        /* Show open menu button */
        .menu-toggle {
            display: block;
        }

        /* Close button hidden initially */
        .menu-close {
            display: none;
            position: absolute;
            left: 0;
            top: 0;
            z-index: 1200;
        }

        /* Menu hidden by default */
        .internal-links {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100vh;
            background: rgba(0, 0, 0, 0.9);
            flex-direction: column;
            align-items: center;
            justify-content: center;
            gap: 2rem;
            opacity: 0;
            visibility: hidden;
            transform: translateY(-10px);
            transition: all 0.3s ease-in-out;
            z-index: 1050;
        }

        /* Show menu when active */
        .internal-links.active {
            opacity: 1;
            visibility: visible;
            transform: translateY(0);
        }

        .internal-links a {
            font-size: 1.5rem;
            color: var(--accent);
        }
        
        /* Contact container goes to single column on mobile */
        .contact-container {
            grid-template-columns: 1fr;
        }
        
        .hero h1 {
            font-size: 2rem;
        }
        
        .contact-info,
        .contact-form {
            margin-bottom: 2rem;
        }
    }
</style>

<script>
    document.addEventListener("DOMContentLoaded", () => {
        // Mobile menu functionality
        const menuToggle = document.getElementById("menu-toggle");
        const menuClose = document.getElementById("menu-close");
        const menu = document.getElementById("menu");

        if (menuToggle && menuClose && menu) {
            // Open menu
            menuToggle.addEventListener("click", () => {
                menu.classList.add("active");
                menuToggle.style.display = "none";
                menuClose.style.display = "block";
            });

            // Close menu
            menuClose.addEventListener("click", () => {
                menu.classList.remove("active");
                menuClose.style.display = "none";
                menuToggle.style.display = "block";
            });

            // Close menu when clicking on links
            const navLinks = menu.querySelectorAll('a');
            navLinks.forEach(link => {
                link.addEventListener('click', () => {
                    menu.classList.remove("active");
                    menuClose.style.display = "none";
                    menuToggle.style.display = "block";
                });
            });
        }

        // Contact form functionality
        const form = document.getElementById('contact-form');
        if (form) {
            form.addEventListener('submit', (e) => {
                e.preventDefault();
                // Here you would typically send the form data to your backend
                // For now, we'll just show a success message
                alert('Thank you for your message! I\'ll get back to you soon.');
                form.reset();
            });
        }
    });
</script>