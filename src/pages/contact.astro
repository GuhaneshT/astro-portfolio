---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Contact | ${SITE_TITLE}`} description="Contact and profile links for Guhanesh T." />
	</head>
	<body>
		<Header />
		<main>
			<section class="contact">
				<div>
					<p class="eyebrow">Contact</p>
					<h1>Let's build something useful.</h1>
					<p>
						I'm open to project discussions, internship conversations, and technical collaboration around
						AI, computer vision, and full-stack software.
					</p>
				</div>
				<div class="links" aria-label="Contact links">
					<a href="https://github.com/GuhaneshT" target="_blank" rel="noreferrer">
						<span>GitHub</span>
						<strong>github.com/GuhaneshT</strong>
					</a>
					<a href="https://leetcode.com/u/gleetcode_23" target="_blank" rel="noreferrer">
						<span>LeetCode</span>
						<strong>leetcode.com/u/gleetcode_23</strong>
					</a>
					<a href="/blog">
						<span>Portfolio</span>
						<strong>View featured projects</strong>
					</a>
					<a href="/about">
						<span>Background</span>
						<strong>Read more about me</strong>
					</a>
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	.contact {
		display: grid;
		grid-template-columns: 1fr 0.9fr;
		gap: 3rem;
		align-items: start;
		min-height: calc(100vh - 260px);
	}

	.contact > div:first-child {
		display: grid;
		gap: 1rem;
	}

	.eyebrow {
		color: var(--accent);
		font-size: 0.82rem;
		font-weight: 800;
		letter-spacing: 0.08em;
		text-transform: uppercase;
	}

	h1 {
		font-size: clamp(3rem, 8vw, 5.5rem);
	}

	.contact p:last-child {
		max-width: 680px;
		color: var(--muted-strong);
		font-size: 1.15rem;
	}

	.links {
		display: grid;
		gap: 1rem;
	}

	.links a {
		display: grid;
		gap: 0.35rem;
		padding: 1.25rem;
		border: 1px solid var(--border);
		border-radius: 8px;
		background: rgba(255, 255, 255, 0.045);
		color: inherit;
		text-decoration: none;
	}

	.links a:hover {
		border-color: var(--border-strong);
	}

	.links span {
		color: var(--accent);
		font-size: 0.85rem;
		font-weight: 800;
		text-transform: uppercase;
	}

	.links strong {
		color: var(--text);
		font-size: 1.15rem;
	}

	@media (max-width: 780px) {
		.contact {
			grid-template-columns: 1fr;
			gap: 2rem;
		}
	}
</style>
