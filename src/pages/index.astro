---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';

const projects = [
	{
		title: 'MPMS',
		description: 'A deployed management platform built for a real workflow, with authentication and productivity-focused screens.',
		stack: ['Full-stack', 'Product Design', 'Workflow Systems'],
		learned: 'Turning a practical requirement into a usable deployed product, with attention to flows, screens, and deployment details.',
		link: 'https://mpms-frontend-zeta.vercel.app/login',
		repo: 'https://github.com/GuhaneshT/YMX-PMS',
	},
	{
		title: 'RopeVim',
		description: 'Rust-based terminal text editor built around the rope data structure.',
		stack: ['Rust', 'Terminal UI', 'Rope Data Structure'],
		learned: 'How editor internals manage large text buffers, cursor movement, and terminal input.',
		link: 'https://github.com/GuhaneshT/RopeVim-Rust_based_terminal_text_editor',
		repo: undefined,
	},
	{
		title: 'SWIM CLI Simulation',
		description: 'Command-line simulation of SWIM-style failure detection for distributed systems.',
		stack: ['Go', 'Distributed Systems', 'CLI'],
		learned: 'How membership protocols detect failures through probing, suspicion, and gossip.',
		link: 'https://github.com/GuhaneshT/SWIM_Simulation_Go',
		repo: undefined,
	},
	{
		title: 'Minecraft DSA Simulation',
		description: 'Minecraft-themed visual simulations for understanding data structures and algorithms.',
		stack: ['DSA', 'Visualization', 'Interactive Learning'],
		learned: 'Explaining algorithms through visual state changes instead of only code or text.',
		link: 'https://github.com/GuhaneshT/Minecraft-DSA',
		repo: undefined,
	},
	{
		title: 'Virtual Classroom Platform',
		description:
			'Remote learning platform with chat, video, quizzes, and a graph neural network recommendation engine.',
		stack: ['Full-stack', 'GNN', 'Realtime'],
		learned: 'Designing product flows around realtime collaboration and recommendation logic.',
		link: 'https://github.com/GuhaneshT/Virtual-classroom---A1',
		repo: undefined,
	},
	{
		title: 'Rip Current Detection',
		description:
			'Computer vision system for identifying rip currents using optical flow on Sony Spresense hardware.',
		stack: ['Computer Vision', 'Optical Flow', 'Edge AI'],
		learned: 'Working with motion signals, noisy visual inputs, and edge-device constraints.',
		link: 'https://github.com/GuhaneshT/RIP-waves',
		repo: undefined,
	},
];

const experience = {
	role: 'Software Engineering Intern',
	company: 'Oracle',
	summary:
		'I worked on migration and release automation for OPERA platform teams, focusing on how existing CI workflows could move into OCI DevOps in a safer, more repeatable way.',
	highlights: [
		'Proposed a Helm-based CI/CD design that connected Shepherd orchestration with OCI DevOps across service onboarding, image deployment, and release automation.',
		'Built migration tooling to convert GitLab CI YAML into validated OCI pipeline configurations for 18+ products and 3,000+ repositories.',
		'Created reusable Terraform modules and API provisioning flows for OCI repositories, build pipelines, deployment stages, and ingress onboarding.',
		'Used Codex and LLM-assisted tooling to scaffold YAML parsers, transformation helpers, validation checks, and documentation, then reviewed the generated output before internal use.',
	],
	learned:
		'The internship taught me how platform work changes when it has to support many teams at once. I learned to think in terms of repeatable release stages, migration safety, validation, and clear documentation instead of one-off scripts. It also gave me practical exposure to OCI DevOps, Terraform, Helm, and the discipline needed when using AI tools inside engineering workflows.',
	stack: ['OCI DevOps', 'Helm', 'Terraform', 'GitLab CI', 'Shepherd', 'YAML', 'LLM-assisted tooling'],
};

const skills = [
	'Python',
	'Java',
	'Go',
	'Software Engineering',
	'Distributed systems',
	'Data Structures and Algorithms',
	'FastAPI',
	'LLMs',
	'OCI',
	'AWS',
	'Terraform',
	'Helm',
	'Rust'
	
];
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} image="/763a681be21a2f18a45b1d0fcabc1650.jpg" />
	</head>
	<body>
		<div class="wrapper">
			<Header />
			<main>
				<section class="hero" aria-labelledby="intro-title">
					<div class="hero-copy">
						<p class="eyebrow">CSE student at Amrita University</p>
						<h1 id="intro-title">Guhanesh T builds AI, vision, and full-stack products.</h1>
						<p class="intro">
							I turn technical ideas into working software: classroom tools, computer vision experiments,
							LLM workflows, and web apps with enough polish to be useful outside a demo.
						</p>
						<div class="actions" aria-label="Primary actions">
							<a class="button primary" href="/blog">View projects</a>
							<a class="button secondary" href="https://github.com/GuhaneshT" target="_blank" rel="noreferrer">GitHub</a>
							<a class="button secondary" href="https://leetcode.com/u/gleetcode_23" target="_blank" rel="noreferrer">LeetCode</a>
						</div>
					</div>
					<div class="profile-panel" aria-label="Profile summary">
						<img src="/763a681be21a2f18a45b1d0fcabc1650-removebg-preview.png" alt="Guhanesh T" />
						<div class="panel-meta">
							<span>Developer</span>
							<span>AI builder</span>
							<span>Problem solver</span>
						</div>
					</div>
				</section>

				<section class="metrics" aria-label="Portfolio highlights">
					<div>
						<strong>{projects.length.toString().padStart(2, '0')}</strong>
						<span>featured builds</span>
					</div>
					<div>
						<strong>AI/CV/DS</strong>
						<span>core interests</span>
					</div>
					<div>
						<strong>Oracle</strong>
						<span>software intern</span>
					</div>
				</section>

				<section class="experience-section" aria-labelledby="experience-title">
					<div class="section-heading">
						<p class="eyebrow">Experience</p>
						<h2 id="experience-title">{experience.company}</h2>
						<p>{experience.role}</p>
					</div>
					<div class="experience-card">
						<p class="experience-summary">{experience.summary}</p>
						<ul class="experience-highlights">
							{experience.highlights.map((highlight) => <li>{highlight}</li>)}
						</ul>
						<div class="experience-learning">
							<h3>What I learned</h3>
							<p>{experience.learned}</p>
						</div>
						<ul class="experience-stack" aria-label="Oracle internship stack">
							{experience.stack.map((item) => <li>{item}</li>)}
						</ul>
					</div>
				</section>

				<section class="section-grid" aria-labelledby="work-title">
					<div class="section-heading">
						<p class="eyebrow">Selected work</p>
						<h2 id="work-title">Projects worth opening from a resume.</h2>
					</div>
					<div class="project-list">
						{projects.map((project) => (
							<article class="project-card">
								<div>
									<h3>{project.title}</h3>
									<p>{project.description}</p>
								</div>
								<ul aria-label={`${project.title} stack`}>
									{project.stack.map((item) => <li>{item}</li>)}
								</ul>
								<p class="learned"><strong>What I learned:</strong> {project.learned}</p>
								<div class="project-links">
									<a href={project.link} target="_blank" rel="noreferrer">Open project</a>
									{project.repo && <a href={project.repo} target="_blank" rel="noreferrer">Source</a>}
								</div>
							</article>
						))}
					</div>
				</section>

				<section class="split-section" aria-labelledby="focus-title">
					<div>
						<p class="eyebrow">Focus</p>
						<h2 id="focus-title">I like projects where software has to reason about messy inputs.</h2>
					</div>
					<p>
						My work sits around practical AI: extracting meaning from documents, detecting patterns in video,
						and building product surfaces that make those systems usable. I care about the path from prototype
						to something another person can actually run, test, and understand.
					</p>
				</section>

				<section class="skills" aria-labelledby="skills-title">
					<div class="section-heading">
						<p class="eyebrow">Toolbox</p>
						<h2 id="skills-title">Technologies I use.</h2>
					</div>
					<ul>
						{skills.map((skill) => <li>{skill}</li>)}
					</ul>
				</section>
			</main>
			<Footer />
		</div>
	</body>
</html>

<style>
	.wrapper {
		min-height: 100vh;
	}

	.hero {
		display: grid;
		grid-template-columns: minmax(0, 1.12fr) minmax(300px, 0.88fr);
		gap: 3rem;
		align-items: center;
		min-height: calc(100vh - 160px);
		padding-bottom: 4rem;
	}

	.hero-copy {
		display: grid;
		gap: 1.5rem;
	}

	.eyebrow {
		color: var(--accent);
		font-size: 0.82rem;
		font-weight: 800;
		letter-spacing: 0.08em;
		text-transform: uppercase;
	}

	h1 {
		max-width: 760px;
		font-size: clamp(3rem, 8vw, 6.25rem);
	}

	.intro {
		max-width: 680px;
		color: var(--muted-strong);
		font-size: 1.25rem;
		line-height: 1.6;
	}

	.actions {
		display: flex;
		flex-wrap: wrap;
		gap: 0.8rem;
	}

	.button {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-height: 48px;
		padding: 0.72rem 1rem;
		border-radius: 8px;
		font-size: 0.98rem;
		font-weight: 800;
		text-decoration: none;
	}

	.button.primary {
		color: #07110d;
		background: var(--accent);
	}

	.button.secondary {
		color: var(--text);
		border: 1px solid var(--border-strong);
		background: rgba(255, 255, 255, 0.06);
	}

	.profile-panel {
		position: relative;
		overflow: hidden;
		border: 1px solid var(--border);
		border-radius: 8px;
		background:
			linear-gradient(160deg, rgba(61, 214, 163, 0.22), transparent 40%),
			linear-gradient(0deg, rgba(255, 255, 255, 0.08), rgba(255, 255, 255, 0.03));
		box-shadow: var(--shadow);
	}

	.profile-panel img {
		width: 100%;
		aspect-ratio: 4 / 5;
		object-fit: contain;
		object-position: bottom center;
		padding: 1.5rem 1.5rem 0;
		background: linear-gradient(180deg, rgba(127, 183, 255, 0.18), rgba(61, 214, 163, 0.08));
	}

	.panel-meta {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		border-top: 1px solid var(--border);
	}

	.panel-meta span {
		padding: 1rem;
		color: var(--muted-strong);
		font-size: 0.88rem;
		font-weight: 700;
		text-align: center;
		border-right: 1px solid var(--border);
	}

	.panel-meta span:last-child {
		border-right: 0;
	}

	.metrics {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 1px;
		overflow: hidden;
		margin-bottom: 5rem;
		border: 1px solid var(--border);
		border-radius: 8px;
		background: var(--border);
	}

	.metrics div {
		padding: 1.25rem;
		background: rgba(255, 255, 255, 0.04);
	}

	.metrics strong,
	.metrics span {
		display: block;
	}

	.metrics strong {
		color: var(--text);
		font-size: 1.55rem;
		line-height: 1.1;
	}

	.metrics span {
		color: var(--muted);
		font-size: 0.95rem;
	}

	.section-grid {
		display: grid;
		grid-template-columns: 0.8fr 1.2fr;
		gap: 2.5rem;
		align-items: start;
		margin-bottom: 5rem;
	}

	.section-heading {
		display: grid;
		gap: 0.8rem;
	}

	.section-heading > p:last-child {
		color: var(--muted-strong);
		font-size: 1.08rem;
		font-weight: 700;
	}

	h2 {
		font-size: clamp(2rem, 4vw, 3.4rem);
	}

	.experience-section {
		display: grid;
		grid-template-columns: 0.8fr 1.2fr;
		gap: 2.5rem;
		align-items: start;
		margin-bottom: 5rem;
	}

	.experience-card {
		display: grid;
		gap: 1.25rem;
		padding: 1.5rem;
		border: 1px solid var(--border);
		border-radius: 8px;
		background: linear-gradient(135deg, rgba(61, 214, 163, 0.08), rgba(127, 183, 255, 0.06));
	}

	.experience-summary,
	.experience-learning p {
		color: var(--muted-strong);
		font-size: 1.08rem;
	}

	.experience-highlights {
		display: grid;
		gap: 0.8rem;
		margin: 0;
		padding-left: 1.1rem;
		color: var(--muted-strong);
	}

	.experience-highlights li::marker {
		color: var(--accent);
	}

	.experience-learning {
		display: grid;
		gap: 0.5rem;
		padding-top: 1rem;
		border-top: 1px solid var(--border);
	}

	.experience-learning h3 {
		font-size: 1.25rem;
	}

	.project-list {
		display: grid;
		gap: 1rem;
	}

	.project-card {
		display: grid;
		gap: 1rem;
		padding: 1.25rem;
		border: 1px solid var(--border);
		border-radius: 8px;
		background: rgba(255, 255, 255, 0.045);
	}

	.project-card h3 {
		margin-bottom: 0.35rem;
		font-size: 1.35rem;
	}

	.project-card p {
		color: var(--muted-strong);
	}

	.project-card .learned {
		padding-top: 0.85rem;
		border-top: 1px solid var(--border);
	}

	.project-card .learned strong {
		color: var(--text);
	}

	.project-card ul,
	.skills ul,
	.experience-stack {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
		padding: 0;
		list-style: none;
	}

	.project-card li,
	.skills li,
	.experience-stack li {
		padding: 0.35rem 0.55rem;
		border: 1px solid var(--border);
		border-radius: 8px;
		color: var(--muted-strong);
		background: rgba(255, 255, 255, 0.04);
		font-size: 0.9rem;
		font-weight: 700;
	}

	.project-links {
		display: flex;
		flex-wrap: wrap;
		gap: 0.9rem;
	}

	.project-card a {
		width: fit-content;
		font-weight: 800;
	}

	.split-section {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 2.5rem;
		align-items: start;
		margin-bottom: 5rem;
		padding: 2rem;
		border: 1px solid var(--border);
		border-radius: 8px;
		background: linear-gradient(135deg, rgba(127, 183, 255, 0.08), rgba(61, 214, 163, 0.06));
	}

	.split-section > div {
		display: grid;
		gap: 0.8rem;
	}

	.split-section p:last-child {
		color: var(--muted-strong);
		font-size: 1.12rem;
	}

	.skills {
		display: grid;
		gap: 1.5rem;
	}

	@media (max-width: 860px) {
		.hero,
		.section-grid,
		.experience-section,
		.split-section {
			grid-template-columns: 1fr;
		}

		.hero {
			min-height: 0;
			gap: 2rem;
		}

		.profile-panel {
			max-width: 460px;
		}
	}

	@media (max-width: 640px) {
		.hero {
			padding-bottom: 3rem;
		}

		h1 {
			font-size: clamp(2.65rem, 16vw, 4.6rem);
		}

		.intro {
			font-size: 1.08rem;
		}

		.metrics {
			grid-template-columns: 1fr;
			margin-bottom: 3.5rem;
		}

		.section-grid,
		.experience-section,
		.split-section {
			margin-bottom: 3.5rem;
		}

		.split-section {
			padding: 1.25rem;
		}

		.panel-meta {
			grid-template-columns: 1fr;
		}

		.panel-meta span {
			border-right: 0;
			border-bottom: 1px solid var(--border);
		}

		.panel-meta span:last-child {
			border-bottom: 0;
		}
	}
</style>
