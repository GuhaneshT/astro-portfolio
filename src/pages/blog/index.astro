---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { SITE_TITLE } from '../../consts';

const projects = [
  {
    title: "Virtual Classroom Platform",
    description: "Remote classroom with chat, video, quizzes, and a GNN-based recommendation engine.",
    image: "https://img.freepik.com/free-vector/online-tutorials-concept_52683-37480.jpg",
    link: "https://github.com/GuhaneshT/Virtual-classroom---A1",
    date: new Date("2024-11-25"),
  },
  {
    title: "Rip Current Detection",
    description: "Computer vision system for detecting rip currents using Optical Flow, built for Sony Spresense.",
    image: "https://img.freepik.com/free-photo/artificial-intelligence-concept_23-2150705237.jpg",
    link: "https://github.com/GuhaneshT/RIP-waves",
    date: new Date("2025-01-10"),
  },
  {
    title: "Invoice AI – SAP Labs",
    description: "LLM-based invoice analysis using Haystack, FastAPI, and AWS. Built for industry use case.",
    image: "https://img.freepik.com/free-vector/invoice-concept-illustration_114360-2271.jpg",
    link: "https://drive.google.com/file/d/1ILuec481Y_Y1Qu8AJFyJ9LWbM3yDA0Qq/view",
    date: new Date("2024-07-01"),
  }
];
---

<html lang="en">
  <head>
    <BaseHead title={`Projects – ${SITE_TITLE}`} description="Guhanesh's featured software and AI projects" />
    <style>
      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        padding: 0;
        font-family: system-ui, sans-serif;
      }

      main {
        max-width: 1200px;
        margin: 2rem auto;
        padding: 1rem;
      }

      h1 {
        text-align: center;
        font-size: 2rem;
        margin-bottom: 2rem;
      }

      ul {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        gap: 2rem;
        list-style: none;
        padding: 0;
        margin: 0;
      }

      li {
        background: rgba(255, 255, 255, 0.02);
        border-radius: 12px;
        overflow: hidden;
        transition: transform 0.2s ease;
        display: flex;
        flex-direction: column;
        height: 100%;
      }

      li:hover {
        transform: translateY(-4px);
      }

      li img {
        width: 100%;
        height: auto;
        display: block;
        border-bottom: 1px solid rgba(255,255,255,0.1);
      }

      .title {
        font-size: 1.2rem;
        font-weight: 600;
        margin: 0.75rem 1rem 0;
        color: rgb(var(--black, 20,20,20));
      }

      .description {
        font-size: 0.95rem;
        color: rgb(var(--gray-dark, 80,80,80));
        margin: 0.5rem 1rem;
      }

      .date {
        font-size: 0.85rem;
        color: rgb(var(--gray, 130,130,130));
        margin: 0 1rem 1rem;
      }

      a {
        text-decoration: none;
        display: block;
        height: 100%;
      }

      a:hover .title,
      a:hover .date {
        color: rgb(var(--accent, 60,130,240));
      }

      @media (max-width: 600px) {
        .title {
          font-size: 1rem;
        }

        .description {
          font-size: 0.875rem;
        }

        .date {
          font-size: 0.75rem;
        }

        main {
          padding: 0.5rem;
        }
      }
    </style>
  </head>

  <body>
    <Header />
    <main>
      <h1>Projects</h1>
      <ul>
        {projects.map((project) => (
          <li>
            <a href={project.link} target="_blank">
              <img
                width="720"
                height="360"
                src={project.image}
                alt={`Cover image for ${project.title}`}
              />
              <h4 class="title">{project.title}</h4>
              <p class="description">{project.description}</p>
              <p class="date">
                {project.date.toLocaleDateString('en-US', {
                  year: 'numeric',
                  month: 'short',
                  day: 'numeric'
                })}
              </p>
            </a>
          </li>
        ))}
      </ul>
    </main>
    <Footer />
  </body>
</html>
