---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE } from '../consts';

const readingItems: string[] = [];
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title={`Reading | ${SITE_TITLE}`}
			description="Technical blogs, books, and notes Guhanesh T is reading."
		/>
	</head>
	<body>
		<Header />
		<main>
			<section class="page-hero">
				<p class="eyebrow">Reading</p>
				<h1>Technical blogs and books</h1>
				<p>
					A place for notes from systems, AI, software engineering, algorithms, and product engineering
					material.
				</p>
			</section>

			<section class="empty-state" aria-label="Reading list">
				{readingItems.length === 0 ? (
					<div>
						<h2>Nothing listed yet.</h2>
						<p>Reading notes and links will show up here when I add them.</p>
					</div>
				) : (
					<ul>
						{readingItems.map((item) => <li>{item}</li>)}
					</ul>
				)}
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	.page-hero {
		display: grid;
		gap: 0.8rem;
		margin-bottom: 2.5rem;
	}

	.eyebrow {
		color: var(--accent);
		font-size: 0.82rem;
		font-weight: 800;
		letter-spacing: 0.08em;
		text-transform: uppercase;
	}

	h1 {
		max-width: 820px;
		font-size: clamp(3rem, 8vw, 5.5rem);
	}

	.page-hero p:last-child {
		max-width: 720px;
		color: var(--muted-strong);
		font-size: 1.18rem;
	}

	.empty-state {
		min-height: 280px;
		display: grid;
		align-items: center;
		padding: 2rem;
		border: 1px solid var(--border);
		border-radius: 8px;
		background: rgba(255, 255, 255, 0.045);
	}

	.empty-state div {
		display: grid;
		gap: 0.6rem;
	}

	h2 {
		font-size: clamp(2rem, 4vw, 3rem);
	}

	.empty-state p {
		color: var(--muted-strong);
	}
</style>
