---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE } from '../consts';

const completedBooks = ['The Silent Patient', 'The Pilgrim'];
const currentBooks = ['The Whisper Man'];
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title={`Reading | ${SITE_TITLE}`}
			description="Technical blogs, books, and notes Guhanesh T is reading."
		/>
	</head>
	<body>
		<Header />
		<main>
			<section class="page-hero">
				<p class="eyebrow">Reading</p>
				<h1>Technical blogs and books</h1>
				<p>
					Things I am reading
				</p>
			</section>

			<section class="reading-grid" aria-label="Reading list">
				<article>
					<p class="label">Reading</p>
					<ul>
						{currentBooks.map((item) => <li>{item}</li>)}
					</ul>
				</article>
				<article>
					<p class="label">Completed</p>
					<ul>
						{completedBooks.map((item) => <li>{item}</li>)}
					</ul>
				</article>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	.page-hero {
		display: grid;
		gap: 0.8rem;
		margin-bottom: 2.5rem;
	}

	.eyebrow {
		color: var(--accent);
		font-size: 0.82rem;
		font-weight: 800;
		letter-spacing: 0.08em;
		text-transform: uppercase;
	}

	h1 {
		max-width: 820px;
		font-size: clamp(3rem, 8vw, 5.5rem);
	}

	.page-hero p:last-child {
		max-width: 720px;
		color: var(--muted-strong);
		font-size: 1.18rem;
	}

	.reading-grid {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 1rem;
	}

	article {
		display: grid;
		align-content: start;
		gap: 1rem;
		min-height: 220px;
		padding: 1.5rem;
		border: 1px solid var(--border);
		border-radius: 8px;
		background: rgba(255, 255, 255, 0.045);
	}

	.label {
		color: var(--accent);
		font-size: 0.85rem;
		font-weight: 800;
		text-transform: uppercase;
	}

	ul {
		display: grid;
		gap: 0.7rem;
		margin: 0;
		padding-left: 1.2rem;
		color: var(--muted-strong);
	}

	li::marker {
		color: var(--accent);
	}

	@media (max-width: 700px) {
		.reading-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
