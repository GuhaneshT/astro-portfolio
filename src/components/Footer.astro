---
const today = new Date();
---

<footer>
	<p>&copy; {today.getFullYear()} Guhanesh T. Built with Astro.</p>
	<nav aria-label="Footer links">
		<a href="/blog">Projects</a>
		<a href="/reading">Reading</a>
		<a href="/about">About</a>
		<a href="https://github.com/GuhaneshT" target="_blank" rel="noreferrer">GitHub</a>
		<a href="https://leetcode.com/u/gleetcode_23" target="_blank" rel="noreferrer">LeetCode</a>
	</nav>
</footer>

<style>
	footer {
		max-width: 1120px;
		margin: 4rem auto 0;
		padding: 2rem 1.25rem 3rem;
		color: var(--muted);
		border-top: 1px solid var(--border);
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
	}

	p {
		margin: 0;
		font-size: 0.95rem;
	}

	nav {
		display: flex;
		flex-wrap: wrap;
		gap: 1rem;
	}

	a {
		color: var(--muted);
		font-size: 0.95rem;
		font-weight: 700;
		text-decoration: none;
	}

	a:hover {
		color: var(--text);
	}

	@media (max-width: 640px) {
		footer {
			align-items: flex-start;
			flex-direction: column;
		}
	}
</style>
