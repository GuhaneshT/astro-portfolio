---
import HeaderLink from './HeaderLink.astro';
---

<header>
    <nav>
        <a class="brand" href="/" aria-label="Guhanesh T home">GT</a>

        <div id="menu" class="internal-links">
            <HeaderLink href="/">Home</HeaderLink>
            <HeaderLink href="/blog">Projects</HeaderLink>
            <HeaderLink href="/reading">Reading</HeaderLink>
            <HeaderLink href="/about">About</HeaderLink>
            <HeaderLink href="/contact">Contact</HeaderLink>
        </div>

        <div class="social-links">
            <a href="https://github.com/GuhaneshT" target="_blank" rel="noreferrer">GitHub</a>
            <a href="https://leetcode.com/u/gleetcode_23" target="_blank" rel="noreferrer">LeetCode</a>
        </div>
    </nav>
</header>

<style>
    header {
        padding: 0 1.25rem;
        background: rgba(12, 17, 24, 0.86);
        border-bottom: 1px solid var(--border);
        backdrop-filter: blur(18px);
        position: sticky;
        top: 0;
        width: 100%;
        z-index: 1000;
    }

    nav {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        max-width: 1120px;
        margin: 0 auto;
        min-height: 68px;
    }

    .brand {
        display: inline-grid;
        place-items: center;
        width: 42px;
        height: 42px;
        border: 1px solid var(--border-strong);
        border-radius: 8px;
        color: var(--text);
        background: var(--surface);
        font-weight: 800;
        text-decoration: none;
        letter-spacing: 0;
    }

    .internal-links {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.25rem;
        padding: 0.35rem;
        border: 1px solid var(--border);
        border-radius: 10px;
        background: rgba(255, 255, 255, 0.04);
    }

    .internal-links :global(a) {
        border-radius: 7px;
        padding: 0.45rem 0.7rem;
    }

    .social-links {
        display: flex;
        gap: 0.8rem;
        justify-content: flex-end;
        min-width: 150px;
    }

    .social-links a {
        color: var(--muted);
        font-size: 0.95rem;
        font-weight: 700;
        text-decoration: none;
    }

    @media (max-width: 720px) {
        header {
            padding: 0 0.8rem;
        }

        nav {
            min-height: 62px;
            gap: 0.55rem;
        }

        .internal-links {
            gap: 0;
            overflow-x: auto;
            justify-content: flex-start;
            scrollbar-width: none;
        }

        .internal-links::-webkit-scrollbar {
            display: none;
        }

        .social-links {
            display: none;
        }

        .brand {
            width: 38px;
            height: 38px;
            flex: 0 0 auto;
        }
    }
</style>
